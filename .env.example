# ─── Browser / Runner ────────────────────────────────────────────────────────

# Base URL for all page.goto() relative calls
BASE_URL=https://sourgum.com

# Base URL used by the ApiClient for direct HTTP requests
API_BASE_URL=https://api.example.com

# Run browsers without a visible window (true = headless, false = headed)
HEADLESS=true

# Set to true in CI pipelines to enable retries and stricter settings
CI=false

# ─── Test Credentials ────────────────────────────────────────────────────────

# Valid user credentials (used in positive login tests)
TEST_USER_EMAIL=your@email.com
TEST_USER_PASSWORD=YourPassword!

# Invalid credentials (used in negative / error-state tests)
TEST_INVALID_EMAIL=invalid@sourgum.com
TEST_INVALID_PASSWORD=WrongPassword123!
